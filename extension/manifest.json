{
  "manifest_version": 3,
  "name": "Softr Studio App Organizer",
  "version": "1.1.0",
  "description": "Sort, filter, and pin apps on Softr Studio (studio.softr.io). Pinned order syncs per workspace; keyboard shortcut for search.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage"],
  "host_permissions": ["https://studio-api.softr.io/*"],
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "focus-app-filter": {
      "suggested_key": {
        "default": "Ctrl+K",
        "mac": "Command+K"
      },
      "description": "Focus Softr Studio app name filter"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["brysk-icon.png"],
      "matches": ["https://studio.softr.io/*"]
    }
  ],
  "content_scripts": [
    {
      "matches": ["https://studio.softr.io/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_start"
    }
  ]
}
